{
  "name": "waypoint",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "An async decision inbox for coding agents: park the fork, keep working, answer when ready.",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "packages/desktop",
    "e2e"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "dev": "npm run dev --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test --pass-with-no-tests",
    "walk": "node --experimental-strip-types scripts/walk.ts",
    "walk:ci": "vitest run --config vitest.walk.config.ts",
    "test:routine": "bash scripts/test-routine.sh",
    "routine:daily": "bash scripts/daily-routine.sh",
    "deploy": "bash scripts/deploy.sh",
    "prod:backup": "bash scripts/prod-backup.sh",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b --noEmit",
    "db:up": "bash scripts/dev-db.sh",
    "dogfood:seed": "node scripts/dogfood-seed.mjs",
    "db:migrate": "node --experimental-strip-types packages/server/src/db/migrate.ts",
    "db:seed": "node --experimental-strip-types packages/server/src/db/seed.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
