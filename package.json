{
  "name": "waypoint",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "An async decision inbox for coding agents: park the fork, keep working, answer when ready.",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "e2e"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "dev": "npm run dev --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b --noEmit",
    "db:migrate": "node --experimental-strip-types packages/server/src/db/migrate.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
