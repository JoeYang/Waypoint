# Copy to .env for local development. .env is gitignored — never commit real secrets.
# These defaults match docker-compose.yml and are LOCAL-ONLY throwaway dev values.

WAYPOINT_DB_USER=waypoint
WAYPOINT_DB_PASSWORD=waypoint_local_dev
WAYPOINT_DB_NAME=waypoint
WAYPOINT_DB_PORT=5432

# Full connection string the backend reads (assembled from the parts above by default).
DATABASE_URL=postgresql://waypoint:waypoint_local_dev@localhost:5432/waypoint
